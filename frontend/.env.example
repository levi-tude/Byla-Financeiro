# Supabase – Painel Byla (demo)
# Copie para .env e preencha com os valores do seu projeto Supabase de demonstração.
# Project URL: Supabase → Project Settings → API → Project URL
# anon key: Supabase → Project Settings → API → Project API Keys → anon public

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# URL pública do painel (sem barra no fim). Obrigatório para o link "Esqueci minha senha" bater com o Supabase.
# Local: http://localhost:5174
# Produção: https://your-frontend.example.com
# NUNCA coloque SUPABASE_SERVICE_ROLE_KEY aqui — só anon no frontend.
# No Supabase: Authentication → URL Configuration → Redirect URLs:
#   http://localhost:5174/redefinir-senha
#   https://your-frontend.example.com/redefinir-senha
VITE_SITE_URL=http://localhost:5174
# Quando o backend estiver com BYLA_AUTH_ENFORCE=true, o frontend envia automaticamente
# o access_token da sessão Supabase no header Authorization.

# Backend (dados completos). Opcional; se vazio, telas usam só Supabase.
# Local: http://localhost:3001
# Produção: https://your-backend.example.com — sem barra no fim
VITE_BACKEND_URL=
