# Copie para .env e preencha os valores. Não versionar .env.

# Render — API Key (Account → API Keys). Usado por: npm run render:status
# RENDER_API_KEY=
# Opcional se o nome do web service não for byla-backend:
# RENDER_SERVICE_NAME=byla-backend

PORT=3001
CORS_ORIGIN=http://localhost:5174
# Se true, rotas protegidas exigem JWT válido + role (profiles).
BYLA_AUTH_ENFORCE=true
# Fallback opcional de role quando profiles ainda não existe (evite em produção)
# BYLA_DEFAULT_ROLE=
# Fonte principal para cadastro operacional: supabase | planilha
BYLA_SOURCE_CADASTRO_PRIMARY=supabase
# Fonte principal para CONTROLE/fluxo: supabase | planilha
BYLA_FLUXO_SOURCE_PRIMARY=supabase

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

GOOGLE_SHEETS_SPREADSHEET_ID=YOUR_SHEET_ID
GOOGLE_SHEETS_FLUXO_ID=YOUR_SHEET_ID
# Planilha Google para export n8n (webhook transacoes → aba Movimentações)
GOOGLE_SHEETS_ENTRADA_SAIDA_ID=YOUR_SHEET_ID
# Com espaço no nome da aba use aspas simples na notação A1 (ou deixe sem aspas; o backend normaliza)
GOOGLE_SHEETS_FLUXO_RANGE='DEMO MES'!A:Z
# Caminho do JSON da service account (ou use GOOGLE_SHEETS_CREDENTIALS_JSON)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Segredo para POST /api/planilha-entrada-saida/sync (header X-Byla-Sync-Secret)
# BYLA_SYNC_SECRET=

# Limite do body JSON global. Default 1mb. Rotas sync autenticadas podem precisar de valor maior no deploy.
# BYLA_JSON_BODY_LIMIT=1mb

# n8n — Public API (opcional). Usado por npm run n8n:list-workflows
# N8N_BASE_URL=https://your-n8n.example.com
# N8N_API_KEY=

# Regras de negócio (opcional — use placeholders em demo)
# Abas elegíveis para conciliação/pagamentos (separadas por vírgula)
# BYLA_ELIGIBLE_SHEETS=MODALIDADE_A,MODALIDADE_B
# Janela em dias para buscar transações do banco ao redor da data de pagamento
# BYLA_BANCO_JANELA_DIAS=7
# Tolerância de valor para match planilha x banco
# BYLA_MATCH_VALOR_TOLERANCIA=0.01
# Dias de tolerância após vencimento para considerar "em dia"
# BYLA_GRACE_DIAS_APOS_VENCIMENTO=5
# Entradas externas ignoradas no extrato (prefixos/trechos, vírgula)
# BYLA_EXTERNAL_ENTRIES=PREFIXO_EXEMPLO
# Prefixo de nome para pareamento de entradas/saídas externas
# BYLA_EXTERNAL_NAME_PREFIX=nome_exemplo
# Tolerância (R$) para pareamento no mesmo dia
# BYLA_EXTERNAL_PAIR_TOLERANCE=100
# Faixa de valores para exclusão de repasse (min/max em R$)
# BYLA_REPASSE_VALOR_MIN=1000
# BYLA_REPASSE_VALOR_MAX=9999

# Funcionários / subempresas (match em planilhas). JSON opcional substitui lista padrão.
# BYLA_FUNCIONARIOS_JSON=[{"nome":"Equipe Demo","funcao":"Staff","aliases":["DEMO"]}]

# IA – Relatórios (pode usar uma ou mais; ordem: Gemini → Groq → OpenAI)
GEMINI_API_KEY=
GROQ_API_KEY=
# OPENAI_API_KEY=

# Minimizar PII nos prompts de IA (padrão true)
# BYLA_IA_MINIMIZE_PII=true

# Rate limits (opcional)
# BYLA_RATE_LIMIT_IA_MAX=20
# BYLA_RATE_LIMIT_IA_WINDOW_MS=900000
# BYLA_RATE_LIMIT_SYNC_MAX=60
# BYLA_RATE_LIMIT_SYNC_WINDOW_MS=900000
